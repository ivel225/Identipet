# Root development environment for IDentiPet.

POSTGRES_DB=identipet
POSTGRES_USER=identipet
POSTGRES_PASSWORD=identipet_dev_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:[YOUR-SUPABASE-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
DATABASE_SSL_REQUIRE=true

DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173

IDENTIPET_JWT_SECRET=replace-with-a-separate-jwt-secret
IDENTIPET_JWT_ISSUER=identipet-api
IDENTIPET_JWT_EXPIRY_MINUTES=120

VITE_API_BASE_URL=http://localhost:8000/api
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000/api
