{
  "expo": {
    "name": "IDentiPet Field",
    "slug": "identipet-field",
    "scheme": "identipet",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.identipet.field",
      "infoPlist": {
        "NFCReaderUsageDescription": "IDentiPet reads NFC pet collar tags to retrieve field identification records."
      }
    },
    "android": {
      "package": "com.identipet.field",
      "permissions": ["android.permission.NFC", "android.permission.INTERNET"],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": false,
          "data": [{ "scheme": "identipet" }],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "plugins": ["expo-router", "expo-secure-store"],
    "extra": {
      "apiBaseUrl": "http://localhost:8000/api",
      "eas": {
        "projectId": "replace-with-eas-project-id"
      }
    }
  }
}
