DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://localhost:3000

POSTGRES_DB=identipet
POSTGRES_USER=identipet
POSTGRES_PASSWORD=identipet_dev_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://identipet:identipet_dev_password@localhost:5432/identipet
USE_DATABASE_URL=true
USE_POSTGRES=false
DATABASE_SSL_REQUIRE=false
DATABASE_CONN_MAX_AGE=600

WHITENOISE_ENABLED=true
DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_SESSION_COOKIE_SECURE=true
DJANGO_CSRF_COOKIE_SECURE=true
DJANGO_SECURE_HSTS_SECONDS=31536000

IDENTIPET_JWT_SECRET=replace-with-a-separate-jwt-secret
IDENTIPET_JWT_ISSUER=identipet-api
IDENTIPET_JWT_EXPIRY_MINUTES=120
