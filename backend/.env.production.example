DJANGO_DEBUG=false
DJANGO_SECRET_KEY=replace-with-50-plus-random-characters
DJANGO_ALLOWED_HOSTS=your-api.example.com
DJANGO_CORS_ALLOWED_ORIGINS=https://your-dashboard.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-api.example.com,https://your-dashboard.example.com

USE_DATABASE_URL=true
USE_POSTGRES=false
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
DATABASE_SSL_REQUIRE=true
DATABASE_CONN_MAX_AGE=600

WHITENOISE_ENABLED=true
DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_SESSION_COOKIE_SECURE=true
DJANGO_CSRF_COOKIE_SECURE=true
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=true
DJANGO_SECURE_HSTS_PRELOAD=false

IDENTIPET_JWT_SECRET=replace-with-a-separate-50-plus-random-character-secret
IDENTIPET_JWT_ISSUER=identipet-api
IDENTIPET_JWT_EXPIRY_MINUTES=120

# Optional first deploy bootstrap. Remove after the first successful deploy.
IDENTIPET_SUPERADMIN_EMAIL=admin@example.com
IDENTIPET_SUPERADMIN_PASSWORD=replace-with-a-strong-password
IDENTIPET_SUPERADMIN_NAME=System Administrator
